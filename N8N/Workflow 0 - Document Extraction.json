    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const data = item.json;\n\n  let text = \"\";\n\n  // Case 1 — ParsedText at root (your current response)\n  if (data.ParsedText) {\n    text = data.ParsedText;\n  }\n\n  // Case 2 — Standard OCR.space structure\n  else if (data.ParsedResults && data.ParsedResults.length > 0) {\n    text = data.ParsedResults[0].ParsedText || \"\";\n  }\n\n  // Case 3 — error message\n  else if (data.ErrorMessage) {\n    text = `[OCR ERROR: ${data.ErrorMessage}]`;\n  }\n\n  else {\n    text = \"[OCR FAILED]\";\n  }\n\n  // clean formatting\n  text = text\n    .replace(/\\r\\n/g, \"\\n\")\n    .replace(/\\n{3,}/g, \"\\n\\n\")\n    .trim();\n\n  return {\n    json: {\n      extracted_text: text\n    }\n  };\n});"
      },
