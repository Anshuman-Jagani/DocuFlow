    {
      "parameters": {
        "jsCode": "const data = $('Get Pending Documents').item.json;\nconst mimeType = data.mime_type || '';\nconst filename = data.original_filename || '';\n\nlet needsOCR = false;\n\nif (mimeType.startsWith('image/') || filename.match(/\\.(png|jpg|jpeg)$/i)) {\n  needsOCR = true;\n}\n\nreturn {\n  json: {\n    document_id: data.id,\n    needs_ocr: needsOCR\n  }\n};"
      },
